{
  "name": "@fal-ai/genmedia-cli",
  "version": "0.1.0",
  "description": "Agent-first CLI for fal.ai — search, run, and manage 600+ generative AI models",
  "type": "module",
  "bin": {
    "falgen": "./dist/falgen"
  },
  "scripts": {
    "build": "bun run scripts/gen-version.ts && bun build --compile --minify --bytecode src/index.ts --outfile dist/falgen",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check src"
  },
  "keywords": [
    "fal",
    "ai",
    "cli",
    "generative",
    "image",
    "video",
    "audio",
    "falgen"
  ],
  "dependencies": {
    "@fal-ai/client": "^1.9.4",
    "chalk": "^5.6.2",
    "citty": "^0.2.1",
    "dotenv": "^17.3.1",
    "ora": "^9.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
