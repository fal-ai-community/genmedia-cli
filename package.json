{
  "name": "@fal-ai/genmedia-cli",
  "version": "0.6.0",
  "description": "Agent-first CLI for fal.ai — search, run, and manage 600+ generative AI models",
  "type": "module",
  "bin": {
    "genmedia": "./dist/genmedia"
  },
  "scripts": {
    "build": "bun run scripts/gen-version.ts && bun build --compile --minify --bytecode src/index.ts --outfile dist/genmedia",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check src",
    "skills:index": "bun run scripts/build-skills-index.ts",
    "skills:index:check": "bun run scripts/build-skills-index.ts --check",
    "prepare": "husky"
  },
  "keywords": [
    "fal",
    "ai",
    "cli",
    "generative",
    "image",
    "video",
    "audio",
    "genmedia"
  ],
  "dependencies": {
    "@fal-ai/client": "^1.10.0",
    "chalk": "^5.6.2",
    "citty": "^0.2.2",
    "dotenv": "^17.4.2",
    "ora": "^9.4.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
